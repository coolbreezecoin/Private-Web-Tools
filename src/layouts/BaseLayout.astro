---
import "@/styles/global.css";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Analytics from "@/components/layout/Analytics.astro";
import { siteName, toAbsoluteUrl } from "@/utils/site";
import { defaultLocale, locales, localizePath, type Locale } from "@/i18n/config";

interface Props {
  title: string;
  description: string;
  basePath?: string;
  locale?: Locale;
  ogImage?: string;
  schema?: Record<string, unknown>[];
}

const { title, description, basePath = "/", locale = defaultLocale, ogImage = "/og-default.png", schema = [] } = Astro.props;
const localizedPath = localizePath(basePath, locale);
const canonical = toAbsoluteUrl(localizedPath);
const alternates = locales.map((item) => ({
  locale: item,
  href: toAbsoluteUrl(localizePath(basePath, item)),
}));
const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const themeScript = `
  const stored = localStorage.getItem("theme");
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
  const theme = stored || (prefersDark ? "dark" : "light");
  document.documentElement.dataset.theme = theme;
`;
const localeDetectScript =
  locale === defaultLocale
    ? `
  (() => {
    if (localStorage.getItem("lang")) return;
    const supported = ${JSON.stringify(locales)};
    const preferred = (navigator.language || "").slice(0, 2).toLowerCase();
    if (!supported.includes(preferred) || preferred === "${defaultLocale}") return;
    const basePath = ${JSON.stringify(basePath)};
    const target = basePath === "/" ? "/" + preferred + "/" : "/" + preferred + basePath;
    location.replace(target);
  })();
`
    : "";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline set:html={themeScript}></script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.locale} href={alternate.href} />)}
    <link rel="alternate" hreflang="x-default" href={toAbsoluteUrl(localizePath(basePath, defaultLocale))} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={toAbsoluteUrl(ogImage)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#4f46e5" />
    {localeDetectScript && <script is:inline set:html={localeDetectScript}></script>}
    {schema.map((entry) => <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />)}
  </head>
  <body>
    <Header locale={locale} basePath={basePath} />
    <slot />
    <Footer locale={locale} />
    <Analytics />
  </body>
</html>
