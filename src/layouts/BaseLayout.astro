---
import "@/styles/global.css";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Analytics from "@/components/layout/Analytics.astro";
import { getCategoryHubByCategory, getCategoryHubByRoute, tools } from "@/data/tools";
import { getCategoryHubContent, getToolContent } from "@/i18n/content";
import { t as getStrings } from "@/i18n/strings";
import { createBreadcrumbSchema } from "@/utils/schema";
import { siteName, toAbsoluteUrl } from "@/utils/site";
import { defaultLocale, locales, localizePath, type Locale } from "@/i18n/config";

interface Props {
  title: string;
  description: string;
  basePath?: string;
  locale?: Locale;
  ogImage?: string;
  schema?: Record<string, unknown>[];
}

const { title, description, basePath = "/", locale = defaultLocale, ogImage = "/og-default.png", schema = [] } = Astro.props;
const normalizedBasePath = basePath.replace(/\/$/, "") || "/";
const localizedPath = localizePath(basePath, locale);
const canonical = toAbsoluteUrl(localizedPath);
const alternates = locales.map((item) => ({
  locale: item,
  href: toAbsoluteUrl(localizePath(basePath, item)),
}));
const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const strings = getStrings(locale);
const matchedTool = tools.find((tool) => tool.route === normalizedBasePath);
const matchedHub = getCategoryHubByRoute(normalizedBasePath);
const toolHub = matchedTool ? getCategoryHubByCategory(matchedTool.category) : undefined;
const breadcrumbItems = matchedTool && toolHub
  ? [
      { name: strings.breadcrumbs.home, path: localizePath("/", locale) },
      { name: getCategoryHubContent(toolHub.category, locale).h1, path: localizePath(toolHub.route, locale) },
      { name: getToolContent(matchedTool.id, locale).name, path: localizePath(matchedTool.route, locale) },
    ]
  : matchedHub
    ? [
        { name: strings.breadcrumbs.home, path: localizePath("/", locale) },
        { name: getCategoryHubContent(matchedHub.category, locale).h1, path: localizePath(matchedHub.route, locale) },
      ]
    : [];
const lastBreadcrumbIndex = breadcrumbItems.length - 1;
const pageSchema = breadcrumbItems.length > 0 ? [createBreadcrumbSchema(breadcrumbItems), ...schema] : schema;
const themeScript = `
  const stored = localStorage.getItem("theme");
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
  const theme = stored || (prefersDark ? "dark" : "light");
  document.documentElement.dataset.theme = theme;
`;
const localeDetectScript =
  locale === defaultLocale
    ? `
  (() => {
    if (localStorage.getItem("lang")) return;
    const supported = ${JSON.stringify(locales)};
    const preferred = (navigator.language || "").slice(0, 2).toLowerCase();
    if (!supported.includes(preferred) || preferred === "${defaultLocale}") return;
    const basePath = ${JSON.stringify(basePath)};
    const target = basePath === "/" ? "/" + preferred + "/" : "/" + preferred + basePath;
    location.replace(target);
  })();
`
    : "";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline set:html={themeScript}></script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.locale} href={alternate.href} />)}
    <link rel="alternate" hreflang="x-default" href={toAbsoluteUrl(localizePath(basePath, defaultLocale))} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={toAbsoluteUrl(ogImage)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#4f46e5" />
    {localeDetectScript && <script is:inline set:html={localeDetectScript}></script>}
    {pageSchema.map((entry) => <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />)}
  </head>
  <body>
    <Header locale={locale} basePath={basePath} />
    {breadcrumbItems.length > 0 && (
      <nav class="breadcrumb page-shell" aria-label={strings.breadcrumbs.label}>
        {breadcrumbItems.map((item, index) => (
          <>
            {index > 0 && <span aria-hidden="true">/</span>}
            {index === lastBreadcrumbIndex ? (
              <span aria-current="page">{item.name}</span>
            ) : (
              <a href={item.path}>{item.name}</a>
            )}
          </>
        ))}
      </nav>
    )}
    <slot />
    <Footer locale={locale} />
    <Analytics />
  </body>
</html>

<style>
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    padding-top: 18px;
    color: var(--color-muted);
    font-size: 13px;
    font-weight: 700;
  }

  .breadcrumb a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
  }

  .breadcrumb span[aria-current="page"] {
    color: var(--color-text);
  }
</style>
