---
const provider = import.meta.env.PUBLIC_ANALYTICS_PROVIDER || "none";
const token = import.meta.env.PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN;
---

{provider === "cloudflare" && token && (
  <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token":"${token}"}`}></script>
)}
