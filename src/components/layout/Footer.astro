---
import { siteName } from "@/utils/site";
import { ui } from "@/i18n/strings";

const year = new Date().getFullYear();
const t = ui.en;
---

<footer class="site-footer">
  <div class="page-shell footer-inner">
    <a class="footer-brand" href="/" aria-label={t.footer.homeLabel}>
      <span class="footer-mark" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
          <path d="M14.7 6.3a4 4 0 0 0-5.4 5.4l-6 6a1.5 1.5 0 0 0 2.1 2.1l6-6a4 4 0 0 0 5.4-5.4l-2.4 2.4-2.1-2.1 2.4-2.4Z" fill="#fff"></path>
        </svg>
      </span>
      <span>{siteName}</span>
      <span class="footer-note">© {year} · {t.footer.privateByDesign}</span>
    </a>
    <nav class="footer-links" aria-label={t.footer.navigationLabel}>
      <a href="/privacy">{t.footer.privacy}</a>
      <a href="/about">{t.footer.about}</a>
      <a href="/all-tools">{t.footer.allTools}</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 40px;
    padding-bottom: 40px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 9px;
    color: var(--color-text);
    font-weight: 800;
    text-decoration: none;
  }

  .footer-mark {
    display: inline-flex;
    width: 26px;
    height: 26px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: var(--color-accent);
  }

  .footer-note {
    margin-left: 6px;
    color: var(--color-muted);
    font-size: 13px;
    font-weight: 600;
  }

  .footer-links {
    display: flex;
    gap: 22px;
  }

  .footer-links a {
    color: var(--color-muted);
    font-size: 13.5px;
    font-weight: 700;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--color-text);
  }

  @media (max-width: 680px) {
    .footer-inner,
    .footer-brand {
      align-items: flex-start;
    }

    .footer-inner,
    .footer-links {
      flex-direction: column;
    }

    .footer-note {
      display: block;
      margin-left: 0;
    }
  }
</style>
