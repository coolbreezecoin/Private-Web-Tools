---
import { getFancyTextTool } from "@/data/tools";
import { getLandingContent, getToolContent } from "@/i18n/content";
import { localizePath, type Locale } from "@/i18n/config";
import { t as getStrings } from "@/i18n/strings";

interface Props {
  currentPath?: string;
  locale: Locale;
}

const { currentPath = "", locale } = Astro.props;
const tool = getFancyTextTool();
const toolContent = getToolContent(tool.id, locale);
const links = [
  { path: tool.route, label: toolContent.name },
  ...tool.landingPages.map((page) => ({
    path: page.route,
    label: getLandingContent(tool.id, page.slug, locale).h1,
  })),
].filter((link) => link.path !== currentPath);
const t = getStrings(locale);
---

<aside class="related" aria-labelledby="related-title">
  <h2 id="related-title">{t.common.relatedTextTools}</h2>
  <div>
    {links.map((link) => <a href={localizePath(link.path, locale)}>{link.label}</a>)}
  </div>
</aside>

<style>
  .related {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-surface);
    padding: 18px;
  }

  h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: 16px;
    letter-spacing: -0.01em;
  }

  div {
    display: grid;
    gap: 8px;
  }

  a {
    display: block;
    border-radius: 10px;
    color: var(--color-muted);
    font-size: 14px;
    font-weight: 700;
    padding: 8px 10px;
    text-decoration: none;
  }

  a:hover {
    background: var(--color-nav-hover);
    color: var(--color-text);
  }
</style>
