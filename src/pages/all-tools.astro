---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ToolDirectory from "@/components/tools/ToolDirectory.svelte";
import { availableTools, comingSoonTools } from "@/data/tools";
import { defaultLocale, localizePath } from "@/i18n/config";
import { getToolContent } from "@/i18n/content";
import { t as getStrings } from "@/i18n/strings";

const locale = defaultLocale;
const basePath = "/all-tools";
const t = getStrings(locale);
const directoryTools = availableTools.map((tool) => {
  const content = getToolContent(tool.id, locale);
  return {
    id: tool.id,
    name: content.name,
    category: tool.category,
    description: content.description,
    route: localizePath(tool.route, locale),
    status: "available" as const,
  };
});
const comingSoon = comingSoonTools.map((tool) => ({
  ...tool,
  ...(t.directory.comingSoonTools[tool.id as keyof typeof t.directory.comingSoonTools] ?? {}),
  status: "comingSoon" as const,
}));
---

<BaseLayout
  title={t.pages.allTools.title}
  description={t.pages.allTools.description}
  basePath={basePath}
  locale={locale}
>
  <main class="page-shell section">
    <section class="prose">
      <h1>{t.pages.allTools.h1}</h1>
      <p>{t.pages.allTools.intro}</p>
    </section>
    <ToolDirectory tools={directoryTools} comingSoon={comingSoon} locale={locale} client:load />
  </main>
</BaseLayout>
