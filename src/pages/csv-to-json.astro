---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdSlot from "@/components/ads/AdSlot.astro";
import HowToFAQ from "@/components/content/HowToFAQ.astro";
import CsvJsonConverter from "@/components/tools/CsvJsonConverter.svelte";
import { availableTools, getCsvJsonTool } from "@/data/tools";
import { defaultLocale, localizePath } from "@/i18n/config";
import { getToolContent } from "@/i18n/content";
import { t as getStrings } from "@/i18n/strings";
import { createFAQSchema, createHowToSchema } from "@/utils/schema";

const locale = defaultLocale;
const tool = getCsvJsonTool();
const content = getToolContent(tool.id, locale);
const seo = { ...content.seo, path: localizePath(tool.route, locale) };
const related = availableTools.filter((item) => item.id !== tool.id);
const t = getStrings(locale);
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
  basePath={tool.route}
  locale={locale}
  schema={[createHowToSchema(content.name, seo, content.howTo), createFAQSchema(content.faq)]}
>
  <main class="page-shell section">
    <section class="tool-hero">
      <p class="eyebrow">{content.privacyNote}</p>
      <h1>{content.name}</h1>
      <p>{content.hero}</p>
    </section>

    <div class="content-grid">
      <div>
        <CsvJsonConverter locale={locale} client:load />
        <section class="landing-copy">
          <h2>{content.bodyTitle ?? content.name}</h2>
          {(content.body ?? []).map((paragraph) => <p>{paragraph}</p>)}
        </section>
        <HowToFAQ howTo={content.howTo} faq={content.faq} />
      </div>
      <aside class="sidebar">
        <aside class="related" aria-labelledby="related-title">
          <h2 id="related-title">{t.common.relatedTools}</h2>
          <div>
            {related.map((item) => <a href={localizePath(item.route, locale)}>{getToolContent(item.id, locale).name}</a>)}
          </div>
        </aside>
        <AdSlot slotId="csv-json-sidebar" reservedHeight={250} />
      </aside>
    </div>
  </main>
</BaseLayout>

<style>
  .tool-hero {
    max-width: 820px;
    margin-bottom: 28px;
  }

  .tool-hero h1 {
    margin: 18px 0 0;
    color: var(--color-text);
    font-size: clamp(40px, 7vw, 62px);
    line-height: 1.03;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .tool-hero p:last-child,
  .landing-copy p {
    max-width: 720px;
    color: var(--color-muted);
    font-size: 17px;
    line-height: 1.7;
  }

  .landing-copy {
    margin-top: 40px;
  }

  .landing-copy h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: clamp(26px, 4vw, 34px);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .sidebar {
    display: grid;
    gap: 16px;
    position: sticky;
    top: 92px;
  }

  .related {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-surface);
    padding: 18px;
  }

  .related h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: 16px;
    letter-spacing: -0.01em;
  }

  .related div {
    display: grid;
    gap: 8px;
  }

  .related a {
    display: block;
    border-radius: 10px;
    color: var(--color-muted);
    font-size: 14px;
    font-weight: 700;
    padding: 8px 10px;
    text-decoration: none;
  }

  .related a:hover {
    background: var(--color-nav-hover);
    color: var(--color-text);
  }

  @media (max-width: 760px) {
    .sidebar {
      position: static;
    }
  }
</style>
