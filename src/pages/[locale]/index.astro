---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TrustStrip from "@/components/layout/TrustStrip.astro";
import ToolDirectory from "@/components/tools/ToolDirectory.svelte";
import { availableTools, comingSoonTools } from "@/data/tools";
import { defaultLocale, isLocale, locales, localizePath, type Locale } from "@/i18n/config";
import { getToolContent } from "@/i18n/content";
import { t as getStrings } from "@/i18n/strings";
import { createWebsiteSchema } from "@/utils/schema";

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale }, props: { locale } }));
}

const locale = isLocale(Astro.props.locale) ? Astro.props.locale : defaultLocale;
const basePath = "/";
const t = getStrings(locale);
const directoryTools = availableTools
  .filter((tool) => tool.visibility.home)
  .map((tool) => {
    const content = getToolContent(tool.id, locale);
    return {
      id: tool.id,
      name: content.name,
      category: tool.category,
      description: content.description,
      route: localizePath(tool.route, locale as Locale),
      status: "available" as const,
    };
  });
const comingSoon = comingSoonTools.map((tool) => ({ ...tool, status: "comingSoon" as const }));
---

<BaseLayout title={t.pages.home.title} description={t.pages.home.description} basePath={basePath} locale={locale} schema={[createWebsiteSchema()]}>
  <main>
    <section class="hero page-shell">
      <p class="eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5l-8-3Z" stroke="currentColor" stroke-width="1.6"></path>
          <path d="m9 11.8 2 2 4-4.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        {t.common.homePrivacyPill}
      </p>
      <h1>{t.common.homeHeroTitlePrefix}{t.common.homeHeroTitleAccent && " "}<span>{t.common.homeHeroTitleAccent}</span>{t.common.homeHeroTitleAccent ? "." : ""}</h1>
      <p class="hero-copy">{t.common.homeHeroCopy}</p>
      <div class="hero-actions">
        <a class="button" href={localizePath("/fancy-text", locale)}>{t.common.openFancyText}</a>
        <a class="button secondary" href={localizePath("/all-tools", locale)}>{t.common.browseTools}</a>
      </div>
    </section>

    <section class="page-shell">
      <ToolDirectory tools={directoryTools} comingSoon={comingSoon} locale={locale} client:load />
      <TrustStrip locale={locale} />
    </section>

    <section class="page-shell section prose home-copy">
      <h2>{t.pages.home.sectionTitle}</h2>
      {t.pages.home.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding-top: 72px;
    padding-bottom: 30px;
  }

  .hero .eyebrow {
    margin: 0 auto 26px;
  }

  h1 {
    max-width: 800px;
    margin: 0 auto;
    color: var(--color-text);
    font-size: clamp(42px, 8vw, 66px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.02;
    text-wrap: balance;
  }

  h1 span {
    color: var(--color-accent);
  }

  .hero-copy {
    max-width: 560px;
    margin: 22px auto 0;
    color: var(--color-muted);
    font-size: 19px;
    line-height: 1.55;
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 30px;
  }

  .home-copy {
    padding-top: 8px;
  }

  @media (max-width: 560px) {
    .hero {
      padding-top: 48px;
    }

    .hero-actions .button {
      width: 100%;
    }
  }
</style>
