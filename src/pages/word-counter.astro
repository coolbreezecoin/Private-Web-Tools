---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdSlot from "@/components/ads/AdSlot.astro";
import HowToFAQ from "@/components/content/HowToFAQ.astro";
import WordCounter from "@/components/tools/WordCounter.svelte";
import { availableTools, getWordCounterTool } from "@/data/tools";
import { createFAQSchema, createHowToSchema } from "@/utils/schema";

const tool = getWordCounterTool();
const related = availableTools.filter((item) => item.id !== tool.id);
---

<BaseLayout
  title={tool.seo.title}
  description={tool.seo.description}
  path={tool.seo.path}
  schema={[createHowToSchema(tool.name, tool.seo, tool.howTo), createFAQSchema(tool.faq)]}
>
  <main class="page-shell section">
    <section class="tool-hero">
      <p class="eyebrow">{tool.privacyNote}</p>
      <h1>{tool.name}</h1>
      <p>
        Paste any draft and instantly count words, characters, characters without spaces, sentences, paragraphs, lines, and estimated reading time.
      </p>
    </section>

    <div class="content-grid">
      <div>
        <WordCounter client:load />
        <section class="landing-copy">
          <h2>Private word counting for everyday writing</h2>
          <p>
            Use this counter for Instagram captions, TikTok descriptions, short essays, blog drafts, product copy, messages, and profile bios. Counts update instantly as you edit.
          </p>
          <p>
            The tool runs in your browser, so your text is not uploaded. It is built for quick checks when you need a clean count without creating an account.
          </p>
        </section>
        <HowToFAQ howTo={tool.howTo} faq={tool.faq} />
      </div>
      <aside class="sidebar">
        <aside class="related" aria-labelledby="related-title">
          <h2 id="related-title">Related tools</h2>
          <div>
            {related.map((item) => <a href={item.route}>{item.name}</a>)}
          </div>
        </aside>
        <AdSlot slotId="word-counter-sidebar" reservedHeight={250} />
      </aside>
    </div>
  </main>
</BaseLayout>

<style>
  .tool-hero {
    max-width: 820px;
    margin-bottom: 28px;
  }

  .tool-hero h1 {
    margin: 18px 0 0;
    color: var(--color-text);
    font-size: clamp(40px, 7vw, 62px);
    line-height: 1.03;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .tool-hero p:last-child,
  .landing-copy p {
    max-width: 720px;
    color: var(--color-muted);
    font-size: 17px;
    line-height: 1.7;
  }

  .landing-copy {
    margin-top: 40px;
  }

  .landing-copy h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: clamp(26px, 4vw, 34px);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .sidebar {
    display: grid;
    gap: 16px;
    position: sticky;
    top: 92px;
  }

  .related {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-surface);
    padding: 18px;
  }

  .related h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: 16px;
    letter-spacing: -0.01em;
  }

  .related div {
    display: grid;
    gap: 8px;
  }

  .related a {
    display: block;
    border-radius: 10px;
    color: var(--color-muted);
    font-size: 14px;
    font-weight: 700;
    padding: 8px 10px;
    text-decoration: none;
  }

  .related a:hover {
    background: var(--color-nav-hover);
    color: var(--color-text);
  }

  @media (max-width: 760px) {
    .sidebar {
      position: static;
    }
  }
</style>
