---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdSlot from "@/components/ads/AdSlot.astro";
import HowToFAQ from "@/components/content/HowToFAQ.astro";
import RelatedFancyPages from "@/components/content/RelatedFancyPages.astro";
import FancyTextGenerator from "@/components/tools/FancyTextGenerator.svelte";
import { getFancyTextTool } from "@/data/tools";
import { defaultLocale, localizePath } from "@/i18n/config";
import { getToolContent } from "@/i18n/content";
import { createFAQSchema, createHowToSchema } from "@/utils/schema";

const locale = defaultLocale;
const tool = getFancyTextTool();
const content = getToolContent(tool.id, locale);
const seo = { ...content.seo, path: localizePath(tool.route, locale) };
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
  basePath={tool.route}
  locale={locale}
  schema={[createHowToSchema(content.name, seo, content.howTo), createFAQSchema(content.faq)]}
>
  <main class="page-shell section">
    <section class="tool-hero">
      <p class="eyebrow">{content.privacyNote}</p>
      <h1>{content.name}</h1>
      <p>{content.hero}</p>
    </section>

    <div class="content-grid">
      <div>
        <FancyTextGenerator locale={locale} client:load />
        <HowToFAQ howTo={content.howTo} faq={content.faq} />
      </div>
      <aside class="sidebar">
        <RelatedFancyPages currentPath={tool.route} locale={locale} />
        <AdSlot slotId="tool-sidebar" reservedHeight={250} />
      </aside>
    </div>
  </main>
</BaseLayout>

<style>
  .tool-hero {
    max-width: 820px;
    margin-bottom: 28px;
  }

  .tool-hero h1 {
    margin: 18px 0 0;
    color: var(--color-text);
    font-size: clamp(40px, 7vw, 62px);
    line-height: 1.03;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .tool-hero p:last-child {
    max-width: 680px;
    color: var(--color-muted);
    font-size: 18px;
    line-height: 1.65;
  }

  .sidebar {
    display: grid;
    gap: 16px;
    position: sticky;
    top: 92px;
  }

  @media (max-width: 760px) {
    .sidebar {
      position: static;
    }
  }
</style>
