---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdSlot from "@/components/ads/AdSlot.astro";
import HowToFAQ from "@/components/content/HowToFAQ.astro";
import RelatedFancyPages from "@/components/content/RelatedFancyPages.astro";
import FancyTextGenerator from "@/components/tools/FancyTextGenerator.svelte";
import { getFancyTextTool } from "@/data/tools";
import { createFAQSchema, createHowToSchema } from "@/utils/schema";

const tool = getFancyTextTool();
---

<BaseLayout
  title={tool.seo.title}
  description={tool.seo.description}
  path={tool.seo.path}
  schema={[createHowToSchema(tool.name, tool.seo, tool.howTo), createFAQSchema(tool.faq)]}
>
  <main class="page-shell section">
    <section class="tool-hero">
      <p class="eyebrow">{tool.privacyNote}</p>
      <h1>{tool.name}</h1>
      <p>
        Type plain text and instantly turn it into bold, italic, cursive, bubble, square, strikethrough, small caps, zalgo, and other copyable Unicode styles.
      </p>
    </section>

    <div class="content-grid">
      <div>
        <FancyTextGenerator client:load />
        <HowToFAQ howTo={tool.howTo} faq={tool.faq} />
      </div>
      <aside class="sidebar">
        <RelatedFancyPages currentPath={tool.seo.path} />
        <AdSlot slotId="tool-sidebar" reservedHeight={250} />
      </aside>
    </div>
  </main>
</BaseLayout>

<style>
  .tool-hero {
    max-width: 820px;
    margin-bottom: 28px;
  }

  .tool-hero h1 {
    margin: 18px 0 0;
    color: var(--color-text);
    font-size: clamp(40px, 7vw, 62px);
    line-height: 1.03;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .tool-hero p:last-child {
    max-width: 680px;
    color: var(--color-muted);
    font-size: 18px;
    line-height: 1.65;
  }

  .sidebar {
    display: grid;
    gap: 16px;
    position: sticky;
    top: 92px;
  }

  @media (max-width: 760px) {
    .sidebar {
      position: static;
    }
  }
</style>
