---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdSlot from "@/components/ads/AdSlot.astro";
import HowToFAQ from "@/components/content/HowToFAQ.astro";
import RelatedFancyPages from "@/components/content/RelatedFancyPages.astro";
import FancyTextGenerator from "@/components/tools/FancyTextGenerator.svelte";
import { getFancyTextTool } from "@/data/tools";
import { defaultLocale, localizePath, type Locale } from "@/i18n/config";
import { getLandingContent, getToolContent } from "@/i18n/content";
import { createFAQSchema, createHowToSchema } from "@/utils/schema";

export function getStaticPaths() {
  const tool = getFancyTextTool();
  return tool.landingPages.map((page) => ({
    params: { slug: page.slug },
    props: { page, locale: defaultLocale },
  }));
}

const tool = getFancyTextTool();
const { page, locale: rawLocale } = Astro.props;
const locale = rawLocale as Locale;
const toolContent = getToolContent(tool.id, locale);
const content = getLandingContent(tool.id, page.slug, locale);
const seo = { ...content.seo, path: localizePath(page.route, locale) };
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
  basePath={page.route}
  locale={locale}
  schema={[createHowToSchema(content.h1, seo, content.howTo), createFAQSchema(content.faq)]}
>
  <main class="page-shell section">
    <section class="tool-hero">
      <p class="eyebrow">{toolContent.privacyNote}</p>
      <h1>{content.h1}</h1>
      <p>{content.intro}</p>
    </section>

    <div class="content-grid">
      <div>
        <FancyTextGenerator featuredStyles={page.featuredStyles} locale={locale} client:load />
        <section class="landing-copy">
          <h2>Copy and paste {content.keyword}</h2>
          {content.body.map((paragraph) => <p>{paragraph}</p>)}
        </section>
        <HowToFAQ howTo={content.howTo} faq={content.faq} />
      </div>
      <aside class="sidebar">
        <RelatedFancyPages currentPath={page.route} locale={locale} />
        <AdSlot slotId={`tool-sidebar-${page.slug}`} reservedHeight={250} />
      </aside>
    </div>
  </main>
</BaseLayout>

<style>
  .tool-hero {
    max-width: 820px;
    margin-bottom: 28px;
  }

  .tool-hero h1 {
    margin: 18px 0 0;
    color: var(--color-text);
    font-size: clamp(40px, 7vw, 62px);
    line-height: 1.03;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .tool-hero p:last-child,
  .landing-copy p {
    max-width: 720px;
    color: var(--color-muted);
    font-size: 17px;
    line-height: 1.7;
  }

  .landing-copy {
    margin-top: 40px;
  }

  .landing-copy h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: clamp(26px, 4vw, 34px);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .sidebar {
    display: grid;
    gap: 16px;
    position: sticky;
    top: 92px;
  }

  @media (max-width: 760px) {
    .sidebar {
      position: static;
    }
  }
</style>
