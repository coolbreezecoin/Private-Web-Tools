---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { defaultLocale } from "@/i18n/config";
import { t as getStrings } from "@/i18n/strings";

const locale = defaultLocale;
const basePath = "/privacy";
const t = getStrings(locale).pages.privacy;
---

<BaseLayout title={t.title} description={t.description} basePath={basePath} locale={locale}>
  <main class="page-shell section prose">
    <h1>{t.h1}</h1>
    <p>{t.intro}</p>
    <h2>{t.inputTitle}</h2>
    <p>{t.inputBody}</p>
    <h2>{t.analyticsTitle}</h2>
    <p>{t.analyticsBody}</p>
    <h2>{t.adsTitle}</h2>
    <p>{t.adsBody}</p>
    <h2>{t.contactTitle}</h2>
    <p>{t.contactBody}</p>
  </main>
</BaseLayout>
